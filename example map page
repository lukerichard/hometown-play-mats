<script>
        // Simple reactive title preview
        const titleInput = document.getElementById('title-input');
        const labelPreview = document.getElementById('label-preview');

        titleInput.addEventListener('input', (e) => {
            labelPreview.textContent = e.target.value || 'Your Title Here';
        });

        // Atmospheric mouse track effect for the map container
        const mapContainer = document.querySelector('.lg\\:col-span-7 .relative');
        mapContainer.addEventListener('mousemove', (e) => {
            const rect = mapContainer.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const moveX = (x / rect.width - 0.5) * 10;
            const moveY = (y / rect.height - 0.5) * 10;
            
            mapContainer.style.transform = `perspective(1000px) rotateY(${moveX}deg) rotateX(${-moveY}deg)`;
        });

        mapContainer.addEventListener('mouseleave', () => {
            mapContainer.style.transform = `perspective(1000px) rotateY(0deg) rotateX(0deg)`;
        });
    </script>
